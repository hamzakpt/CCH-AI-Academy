{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    /* Build + Composite */
    "composite": true,

    /* Target & libs */
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    /* Modules */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": false,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@ai-adventure/*": ["src/ai-adventure/*"],
      "@learning-path/*": ["src/learning-path/*"],
      "@shared/*": ["src/shared/*"]
    }
  },

  "include": [
    "src/vite-env.d.ts",
    "src/ai-adventure",
    "src/learning-path",
    "src/shared",
    "src/admin"
  ]
}
