# Ignore node_modules, it will be installed in the container
node_modules

# Ignore build output, it will be generated in the container
dist

# Ignore local development files
.env
.env*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore git files
.git
.gitignore

# Ignore Docker files
Dockerfile
.dockerignore

# Ignore development/documentation
README.md
*.md
.vscode
.editorconfig
.eslintignore
.prettierignore

# Ignore CI/CD files
.github
.gitlab-ci.yml
.circleci

# Ignore IDE files
*.swp
*.swo
*~
.idea
*.iml
